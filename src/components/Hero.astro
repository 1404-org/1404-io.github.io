---
import { SITE } from '../lib/constants';
---

<section class="min-h-screen flex flex-col items-center justify-center px-6 pt-16">
  <div class="text-center max-w-4xl mx-auto">

    <!-- Tagline -->
    <h1 class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-text-primary leading-tight mb-8">
      Agents that run your operations
    </h1>

    <!-- Description -->
    <p class="text-text-secondary text-base sm:text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-12">
      1404 builds teams of AI agents that handle operational work inside your company — financial reporting, executive briefings, business development, deal tracking, exit preparation. They're trained on your business, connected to the systems you already use, and we manage them on an ongoing basis.
    </p>

    <!-- CTAs -->
    <div class="flex items-center justify-center gap-6 sm:gap-8">
      <a
        href={SITE.booking}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-copper text-bg px-6 py-3 text-sm font-medium tracking-wide hover:bg-copper-bright transition-colors duration-200"
      >
        Book a Call
      </a>
      <a
        href="/how-it-works"
        class="text-sm text-text-secondary hover:text-text-primary transition-colors duration-200"
      >
        How it works &rarr;
      </a>
    </div>
  </div>
</section>
