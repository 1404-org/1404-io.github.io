---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout
  title="Demos | 1404"
  description="Direct URL access only."
  noindex={true}
>
  <section class="max-w-3xl mx-auto px-6 pt-40 pb-24">
    <p class="text-xs tracking-widest uppercase text-copper mb-4">Demos</p>
    <h1 class="font-display text-4xl text-text-primary leading-tight mb-8">
      Direct access only
    </h1>
    <p class="text-text-body text-base leading-relaxed mb-6">
      Demo pages are sent directly to prospects via the URL on their proposal. There is no public index.
    </p>
    <p class="text-text-body text-base leading-relaxed">
      If you arrived here looking for product information, the right starting points are <a href="/agents" class="text-copper hover:text-copper-bright">Agent Suites</a> or <a href="/how-it-works" class="text-copper hover:text-copper-bright">How It Works</a>.
    </p>
  </section>
</PageLayout>
