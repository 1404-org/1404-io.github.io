---
import PageLayout from '../../layouts/PageLayout.astro';

// Per-persona demos pages. URL-only — not linked from nav, noindex, robots.txt disallow.
// Each entry produces a route at /demos/<slug>.
//
// To add a persona:
//   1. Drop preview PNG + real file (.xlsx or .pdf) into public/demos/<slug>/
//   2. Add an entry to PERSONAS inside getStaticPaths below
//   3. Each deliverable: { preview, file, type, name, description }
//      - preview: PNG filename used as the visual
//      - file: real openable file (xlsx or pdf)
//      - type: 'xlsx' | 'pdf'
//      - name: short title
//      - description: 1-2 sentence explanation

export function getStaticPaths() {
  const PERSONAS = [
    {
      slug: 're-developer',
      industry: 'Real Estate Development',
      intro: 'Sample deliverables produced by the Real Estate Development persona. Each one is generated from live system data — pro formas pull from your underwriting model, draw packages assemble from your project management system, IC memos draft from underwriting outputs and comparable transactions, investor reports build from accounting and capital account data. Click any file below to open the real spreadsheet or PDF. These are 1404-branded test outputs; in a real engagement they carry your brand.',
      deliverables: [
        {
          preview: 'dev-pro-forma.png',
          file: 'dev-pro-forma.xlsx',
          type: 'xlsx',
          name: 'Development pro forma',
          description: 'Multi-tab Excel model: Summary, Assumptions, Sources & Uses, Revenue, OpEx, NOI & Cash Flow, Waterfall, Sensitivity. Updates when assumptions change.',
        },
        {
          preview: 'ic-memo.png',
          file: 'ic-memo.pdf',
          type: 'pdf',
          name: 'Investment committee memo',
          description: 'Eleven-page IC memo with deal summary, market analysis, sponsor comparables, financial projections, risk register, and recommendation. Drafted from underwriting and comp data.',
        },
        {
          preview: 'draw-package.png',
          file: 'draw-package.xlsx',
          type: 'xlsx',
          name: 'Construction draw package',
          description: 'Six-tab Excel: Draw Summary, G702, G703, Change Order Log, Budget Summary, Lien Waiver Tracker. Assembled from project management and accounting systems.',
        },
        {
          preview: 'investor-report.png',
          file: 'investor-report.pdf',
          type: 'pdf',
          name: 'Quarterly investor report',
          description: 'Eight-page LP-facing quarterly report with portfolio summary, per-asset performance, capital account roll-forward, and waterfall status. Drafted from live operating and accounting data.',
        },
      ],
    },
    {
      slug: 'construction',
      industry: 'Construction',
      intro: 'Sample deliverables produced by the Construction persona. Bids assemble from rate cards and takeoffs, AIA pay applications draft from job cost and schedule of values, WIP schedules calculate percentage-of-completion from live cost data, and COI compliance tracks insurance status across every active subcontractor. Click any file below to open the real spreadsheet or PDF. These are 1404-branded test outputs; in a real engagement they carry your brand.',
      deliverables: [
        {
          preview: 'bid-proposal.png',
          file: 'bid-proposal.pdf',
          type: 'pdf',
          name: 'Bid proposal',
          description: 'Nine-page branded bid package with scope of work, line-item pricing from rate card, exclusions, qualifications, and submittal. Drafted from takeoff data and project specs.',
        },
        {
          preview: 'aia-pay-app.png',
          file: 'aia-pay-app.xlsx',
          type: 'xlsx',
          name: 'AIA pay application',
          description: 'G702 and G703 pay application sheets with continuation, retention calculation, change order tracking, and schedule of values reconciliation. Generated from job cost data.',
        },
        {
          preview: 'wip-schedule.png',
          file: 'wip-schedule.xlsx',
          type: 'xlsx',
          name: 'WIP schedule',
          description: 'Three-tab Excel: WIP Schedule, Prior Period, Change Log. Percentage-of-completion revenue recognition, billings in excess, costs in excess, and gross profit by job.',
        },
        {
          preview: 'coi-tracker.png',
          file: 'coi-tracker.xlsx',
          type: 'xlsx',
          name: 'COI compliance dashboard',
          description: 'Three-tab Excel: Dashboard, All Subcontractors, Expiring Soon. Tracks coverage limits, expiry dates, additional insured status, and waiver of subrogation across every sub.',
        },
      ],
    },
  ];

  return PERSONAS.map((p) => ({
    params: { persona: p.slug },
    props: { persona: p },
  }));
}

const { persona } = Astro.props;
---

<PageLayout
  title={`${persona.industry} — Sample Deliverables | 1404`}
  description={`Live sample deliverables produced by the 1404 ${persona.industry} agent persona.`}
  noindex={true}
>
  <section class="max-w-5xl mx-auto px-6 pt-40 pb-24 md:pb-32">
    <header class="mb-16">
      <p class="text-xs tracking-widest uppercase text-copper mb-4">Sample deliverables</p>
      <h1 class="font-display text-4xl md:text-5xl text-text-primary leading-tight mb-8">
        {persona.industry}
      </h1>
      <p class="text-text-body text-base leading-relaxed max-w-3xl">
        {persona.intro}
      </p>
    </header>

    <div class="space-y-20">
      {persona.deliverables.map((d) => {
        const fileUrl = `/demos/${persona.slug}/${d.file}`;
        const previewUrl = `/demos/${persona.slug}/${d.preview}`;
        const typeLabel = d.type === 'xlsx' ? 'Excel · xlsx' : 'PDF';
        const actionLabel = d.type === 'xlsx' ? 'Download Excel model' : 'Open PDF';
        return (
          <article class="border-t border-border pt-12">
            <div class="mb-6 flex flex-wrap items-baseline gap-x-4 gap-y-2">
              <h2 class="font-display text-2xl md:text-3xl text-text-primary">{d.name}</h2>
              <span class="font-mono text-xs uppercase tracking-wider text-copper border border-copper-dim px-2 py-1">
                {typeLabel}
              </span>
            </div>
            <p class="text-text-secondary text-sm leading-relaxed max-w-2xl mb-6">{d.description}</p>

            <a
              href={fileUrl}
              target="_blank"
              rel="noopener"
              class="block group mb-4"
              aria-label={`${actionLabel} — ${d.name}`}
            >
              <div class="border border-border-light bg-bg-card overflow-hidden group-hover:border-copper-dim transition-colors duration-200">
                <img
                  src={previewUrl}
                  alt={`${d.name} preview`}
                  loading="lazy"
                  class="w-full h-auto block"
                />
              </div>
            </a>

            <div class="flex items-center gap-4">
              <a
                href={fileUrl}
                target="_blank"
                rel="noopener"
                download
                class="inline-block border border-copper text-copper hover:bg-copper hover:text-bg px-5 py-2 text-sm tracking-wide transition-colors duration-200"
              >
                {actionLabel} &rarr;
              </a>
              <a
                href={previewUrl}
                target="_blank"
                rel="noopener"
                class="text-xs text-text-muted hover:text-text-secondary transition-colors"
              >
                View preview full size
              </a>
            </div>
          </article>
        );
      })}
    </div>

    <div class="border-t border-border mt-24 pt-16">
      <h2 class="font-display text-2xl md:text-3xl text-text-primary mb-6">Want to see this for your business?</h2>
      <p class="text-text-body text-base leading-relaxed mb-8 max-w-2xl">
        These are samples — built once, never connected to a real operating company. In an engagement, every deliverable on this page is generated from your live data, branded for your firm, and runs on your operating cadence. The first 30 days produces a working version connected to your systems.
      </p>
      <a
        href="/contact"
        class="inline-block border border-copper text-copper hover:bg-copper hover:text-bg px-6 py-3 text-sm tracking-wide transition-colors duration-200"
      >
        Talk to us
      </a>
    </div>
  </section>
</PageLayout>
