---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTABanner from '../components/CTABanner.astro';
import { SUITES } from '../lib/constants';

// Deliverable cards — add real entries here as they're ready.
// Each card: { title, suite, description, thumbnail? }
const deliverables: {
  title: string;
  suite: string;
  description: string;
  thumbnail?: string;
}[] = [];

// Placeholder cards shown when there aren't enough real deliverables yet
const placeholderCount = Math.max(0, 3 - deliverables.length);
---

<PageLayout
  title="Work — 1404 | Agent Deliverables"
  description="Real deliverables produced by 1404's AI agent teams. Executive reports, financial analysis, prospect research, and more."
>
  <!-- Header -->
  <section class="max-w-5xl mx-auto px-6 pt-32 pb-16 md:pt-40 md:pb-20">
    <SectionHeading
      title="Work"
      subtitle="Real output from our agent teams. These are actual deliverables produced for our clients."
    />

    <div class="space-y-6 text-text-body text-base leading-relaxed">
      <p>
        The best way to understand what an agent team can do is to see what it produces. Below are examples of actual deliverables generated by our agent suites for real clients. Each one was produced by an agent, reviewed by our team, and delivered to the client.
      </p>
      <p>
        Every example below is an actual deliverable produced for a client as part of a live engagement.
      </p>
    </div>
  </section>

  <!-- Deliverables Grid -->
  <section class="border-t border-border">
    <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
      <SectionHeading title="Deliverables" />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {/* Real deliverable cards */}
        {deliverables.map((item) => (
          <div class="border border-border-light rounded-sm bg-bg-card overflow-hidden">
            {item.thumbnail ? (
              <img src={item.thumbnail} alt={item.title} class="w-full h-48 object-cover" />
            ) : (
              <div class="w-full h-48 bg-bg-surface flex items-center justify-center">
                <span class="text-text-muted text-sm font-mono">Preview</span>
              </div>
            )}
            <div class="p-6">
              <p class="font-mono text-xs text-copper mb-2 tracking-wide">{item.suite}</p>
              <h3 class="font-display text-lg text-text-primary mb-2">{item.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}

        {/* Placeholder cards */}
        {Array.from({ length: placeholderCount }).map(() => (
          <div class="border border-border-light rounded-sm bg-bg-card overflow-hidden">
            <div class="w-full h-48 bg-bg-surface flex items-center justify-center">
              <div class="w-10 h-10 border border-border-light rounded-sm flex items-center justify-center">
                <span class="text-text-muted text-lg">+</span>
              </div>
            </div>
            <div class="p-6">
              <p class="font-mono text-xs text-text-muted mb-2 tracking-wide">COMING SOON</p>
              <h3 class="font-display text-lg text-text-muted mb-2">New deliverable</h3>
              <p class="text-text-muted text-sm leading-relaxed">
                More examples from our agent suites will be added here as client engagements produce shareable work.
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What You'll See Here -->
  <section class="border-t border-border">
    <div class="max-w-5xl mx-auto px-6 py-24 md:py-32">
      <SectionHeading title="What you'll find here" />

      <p class="text-text-body text-base leading-relaxed mb-12">
        Every suite produces different types of output. As we add deliverables to this page, here's the kind of work you can expect to see.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SUITES.map((suite) => (
          <div class="border border-border-light rounded-sm px-5 py-4 bg-bg-card">
            <p class="font-mono text-xs text-copper mb-1 tracking-wide">{suite.name}</p>
            <p class="text-text-secondary text-sm">{suite.short}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner />
</PageLayout>
