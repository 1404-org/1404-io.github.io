---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout
  title="Case Studies — 1404 | Technology Results"
  description="Real results from real engagements. See what a purpose-built technology department actually delivers."
>
  <section class="max-w-4xl mx-auto px-6 pt-40 pb-24 md:pb-32">

    <!-- Header -->
    <header class="mb-20">
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-text-primary leading-tight">
        Case Studies
      </h1>
      <p class="text-text-secondary text-lg mt-6 leading-relaxed">
        What it actually looks like when we build a technology department for a company.
      </p>
    </header>

    <!-- TCG Case Study -->
    <a href="/case-studies/tcg" class="group block border-b border-border pb-12">
      <p class="text-xs tracking-widest uppercase text-text-muted mb-3">Retail Fixture Installation</p>
      <h2 class="font-display text-2xl md:text-3xl text-text-primary mb-4 group-hover:text-copper transition-colors duration-200">
        The Construct Group
      </h2>
      <p class="text-text-secondary text-base leading-relaxed">
        From spreadsheets to a unified operations platform — 12 integrated modules covering project management, labor forecasting, inventory, purchasing, scheduling, financials, and AI operations. Built and deployed in two months.
      </p>
    </a>

  </section>
</PageLayout>
